# TikTok Developer Portal → Your App → Basic Information
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Must match the Redirect URI registered in TikTok Developer Portal
# For local dev: use ngrok (TikTok requires HTTPS for production, localhost works for sandbox)
REDIRECT_URI=http://localhost:3000/auth/callback

PORT=3000
